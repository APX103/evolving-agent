# Kimi API 配置
# 获取 API Key: https://platform.moonshot.cn/
kimi:
  api_key: "your-kimi-api-key-here"   # 必填：你的 Kimi API Key
  base_url: "https://api.moonshot.cn/v1"   # Moonshot API（需单独充值）
  # base_url: "https://api.kimi.com/coding/v1"  # Kimi Code backend（coding plan 套餐通用）
  model: "kimi-latest"                  # 可选: kimi-latest, kimi-k2, kimi-k2-0711-preview 等
  embedding_model: "text-embedding"   # Embedding 模型
  max_tokens: 4096
  temperature: 0.7
  user_agent: ""                        # 特殊客户端标识，如 "KimiCLI/1.3"

# Agent 基础配置
agent:
  name: "Evo"                           # Agent 的名字
  language: "zh"                        # 默认语言: zh/en
  max_short_term_turns: 10              # 短期记忆保留最近 N 轮
  learn_after_session: true             # 会话结束后是否自动学习
  reflect_threshold: 5                  # 积累 N 个会话后触发反思

# 记忆存储路径
storage:
  base_path: "./storage"
  conversations: "./storage/conversations"
  knowledge: "./storage/knowledge"
  user_profile: "./storage/user_profile"
  reflections: "./storage/reflections"
  personality: "./storage/personality"
  relationship: "./storage/relationship"
  mood: "./storage/mood"

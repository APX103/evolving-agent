# Kimi API 配置
# 获取 API Key: https://platform.moonshot.cn/
kimi:
  api_key: "your-kimi-api-key-here"   # 必填：你的 Kimi API Key
  base_url: "https://api.moonshot.cn/v1"   # Moonshot API（需单独充值）
  # base_url: "https://api.kimi.com/coding/v1"  # Kimi Code backend（coding plan 套餐通用）
  model: "kimi-latest"                  # 可选: kimi-latest, kimi-k2, kimi-k2-0711-preview 等
  embedding_model: "text-embedding"   # Embedding 模型
  max_tokens: 4096
  temperature: 0.7
  user_agent: ""                        # 特殊客户端标识，如 "KimiCLI/1.3"

# Agent 基础配置
agent:
  name: "Evo"                           # Agent 的名字
  language: "zh"                        # 默认语言: zh/en
  max_short_term_turns: 10              # 短期记忆保留最近 N 轮
  learn_after_session: true             # 会话结束后是否自动学习
  reflect_threshold: 5                  # 积累 N 个会话后触发反思

# MCP (Model Context Protocol) 配置
# 接入外部工具生态：https://modelcontextprotocol.io/
mcp:
  enabled: false                       # 是否启用 MCP
  servers:
    - name: "filesystem"
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-filesystem", "/Users"]  # 文件系统访问
    - name: "fetch"
      transport: "stdio"
      command: "uvx"
      args: ["mcp-server-fetch"]        # HTTP 请求/网页获取
    # - name: "playwright"
    #   transport: "stdio"
    #   command: "npx"
    #   args: ["-y", "@anthropic-ai/mcp-server-playwright"]  # 浏览器自动化

# 敏感操作审批配置
approval:
  enabled: true                        # 是否启用人工审批
  require_approval_for:                # 哪些操作需要审批
    - "shell"
    - "file_write"
    - "mcp:filesystem:write"

# 多 Agent 协作配置 (v4.0+)
 multi_agent:
   enabled: true                       # 启用多 Agent 模式
   default_agent: "companion"          # 默认 Agent
   router_temperature: 0.3             # Router 意图分类温度
   context_budget: 3500                # 上下文总预算 (tokens)
   session_ttl: 1800                   # 会话超时 (秒)

 # 飞书机器人配置 (v4.0+)
 feishu:
   enabled: false                      # 是否启用飞书机器人
   app_id: "cli_xxxxxxxx"             # 飞书应用 ID
   app_secret: "xxxxxxxx"             # 飞书应用密钥
   encrypt_key: ""                     # 加密密钥（可选）
   verification_token: ""              # 验证令牌（可选）
   bot_name: "Evo"                     # 机器人名称（群聊 @用）

 # 记忆存储路径
 storage:
   base_path: "./storage"
   conversations: "./storage/conversations"
   knowledge: "./storage/knowledge"
   user_profile: "./storage/user_profile"
   reflections: "./storage/reflections"
   personality: "./storage/personality"
   relationship: "./storage/relationship"
   mood: "./storage/mood"

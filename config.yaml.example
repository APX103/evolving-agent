# Kimi API configuration
# Get API Key: https://platform.moonshot.cn/
kimi:
  api_key: "your-kimi-api-key-here"   # Required: your Kimi API Key
  base_url: "https://api.moonshot.cn/v1"   # Moonshot API
  # base_url: "https://api.kimi.com/coding/v1"  # Kimi Code backend
  model: "kimi-latest"                  # Optional: kimi-latest, kimi-k2, etc.
  embedding_model: "text-embedding"   # Embedding model
  max_tokens: 4096
  temperature: 0.7
  user_agent: ""                        # Special client identifier

# Agent base configuration
agent:
  name: "Evo"                           # Agent name
  language: "zh"                        # Default language: zh/en
  max_short_term_turns: 10              # Short-term memory turns
  learn_after_session: true             # Auto-learn after session
  reflect_threshold: 5                  # Reflection threshold

# MCP (Model Context Protocol) configuration
# Connect external tool ecosystem: https://modelcontextprotocol.io/
mcp:
  enabled: false                       # Enable MCP
  servers:
    - name: "filesystem"
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-filesystem", "/Users"]
    - name: "fetch"
      transport: "stdio"
      command: "uvx"
      args: ["mcp-server-fetch"]
    # HTTP transport example (SSE)
    # - name: "remote-echo"
    #   transport: "sse"
    #   url: "http://localhost:3000/sse"
    # Streamable HTTP transport example
    # - name: "remote-http"
    #   transport: "http"
    #   url: "http://localhost:3000/mcp"
  security:
    enabled: true
    policy:
      low: "allow"
      medium: "allow"
      high: "require_approval"
      critical: "block"
    blocked_tools: []                   # Explicitly blocked tool names or server::tool keys

# A2A (Agent-to-Agent) protocol configuration
# Discover and delegate tasks to external A2A-compatible agents
a2a:
  enabled: false                       # Enable A2A external agent discovery
  external_agents: []                  # List of base URLs to discover
  # example:
  #   - "http://localhost:8001"
  #   - "http://localhost:8002"
  discovery_ttl_seconds: 300           # Cache TTL for agent discovery

# Sensitive operation approval configuration
approval:
  enabled: true                        # Enable human approval
  mode: "blocking"                     # blocking | nonblocking | auto
  require_approval_for:
    - "shell"
    - "file_write"
    - "mcp:filesystem:write"

# Multi-agent collaboration configuration (v4.0+)
 multi_agent:
   enabled: true
   default_agent: "companion"
   router_temperature: 0.3
   context_budget: 3500
   session_ttl: 1800

 # Feishu bot configuration (v4.0+)
 feishu:
   enabled: false
   app_id: "cli_xxxxxxxx"
   app_secret: "xxxxxxxx"
   encrypt_key: ""
   verification_token: ""
   bot_name: "Evo"

 # Storage paths
 storage:
   base_path: "./storage"
   conversations: "./storage/conversations"
   knowledge: "./storage/knowledge"
   user_profile: "./storage/user_profile"
   reflections: "./storage/reflections"
   personality: "./storage/personality"
   relationship: "./storage/relationship"
   mood: "./storage/mood"
